generator client {
    provider      = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ContactForm {
    id        Int      @id @default(autoincrement())
    nombre    String
    email     String
    telefono  String?
    mensaje   String   @db.Text
    estado    String   @default("nuevo")
    createdAt DateTime @default(now())

    @@index([createdAt])
    @@index([estado])
}
