generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output        = "/home/ubuntu/lrp_proyectos_tecnicos/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ContactForm {
    id        Int      @id @default(autoincrement())
    nombre    String
    email     String
    telefono  String?
    mensaje   String   @db.Text
    estado    String   @default("nuevo")
    createdAt DateTime @default(now())

    @@index([createdAt])
    @@index([estado])
}
