generator client {
    provider      = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ContactForm {
    id        Int      @id @default(autoincrement())
    nombre    String
    email     String
    telefono  String?
    mensaje   String   @db.Text
    estado    String   @default("nuevo")
    createdAt DateTime @default(now())

    @@index([createdAt])
    @@index([estado])
}

model PortfolioProject {
    id               Int      @id @default(autoincrement())
    titulo           String
    slug             String   @unique
    categoria        String
    ubicacion        String
    anio             Int
    descripcion      String   @db.Text
    imagenPrincipal  String
    imagenes         String[]
    destacado        Boolean  @default(false)
    publicado        Boolean  @default(true)
    orden            Int      @default(0)
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    @@index([publicado, orden])
    @@index([categoria])
    @@index([anio])
}

model AdminUser {
    id           Int      @id @default(autoincrement())
    nombre       String
    email        String   @unique
    passwordHash String
    activo       Boolean  @default(true)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([activo])
}
